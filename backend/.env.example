# Optional API keys
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
POLYGON_API_KEY=

# Market data provider priority (yahoo | alpha_vantage | finnhub | polygon)
MARKET_DATA_PROVIDER=yahoo

# Banco de la Republica endpoints (optional, configurable)
BANREP_ENABLED=false
BANREP_FX_URL=
BANREP_RISK_FREE_URL=
BANREP_INFLATION_URL=

# App metadata
APP_NAME=Proyecto Teoria de Riesgo API
APP_VERSION=1.0.0

# Defaults
DEFAULT_BENCHMARK=SPY
DEFAULT_START_DATE=2023-01-01

# Indicator params
SMA_WINDOW=20
EMA_WINDOW=20
RSI_WINDOW=14
BB_WINDOW=20
BB_STD=2.0
STOCH_WINDOW=14

# Risk params
DEFAULT_CONFIDENCE=0.95
MONTE_CARLO_SIMS=10000
TRADING_DAYS_PER_YEAR=252
